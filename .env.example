# Copy this file to ".env" and fill in your own key(s).
# The real .env is git-ignored and must NEVER be committed.
#
# Used only by the local image generator (tools/generate_images.py) to
# pre-generate food/recipe images. The published static site never reads these.

# OpenAI GPT Image — default provider
OPENAI_API_KEY=your-openai-api-key-here

# Leonardo.ai — optional alternative (run with --provider leonardo)
LEONARDO_API_KEY=your-leonardo-api-key-here
